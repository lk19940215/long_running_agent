                          "id": "step-3",
                          "layout": "horizontal",
                          "gap": 8,
                          "children": [
                            {
                              "type": "text",
                              "id": "arrow-3",
                              "content": "→",
                              "fontSize": 16,
                              "fill": "$sys/color.gradient-start"
                            },
                            {
                              "type": "text",
                              "id": "step-3-text",
                              "content": "第一个项目：",
                              "fontSize": 14,
                              "fontWeight": "400",
                              "fill": "$sys/color.text-400"
                            },
                            {
                              "type": "frame",
