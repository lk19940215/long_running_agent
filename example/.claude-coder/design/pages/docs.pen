{
  "version": "2.8",
  "imports": {
    "sys": "../system.pen"
  },
  "children": [
    {
      "type": "frame",
      "id": "docs-page",
      "name": "文档中心",
      "x": 0,
      "y": 0,
      "width": 1440,
      "height": 2200,
      "clip": true,
      "fill": "$sys/color.bg-100",
      "children": [
        {
          "type": "frame",
          "id": "page-header",
          "x": 200,
          "y": 120,
          "width": 800,
          "height": 100,
          "layout": "vertical",
          "gap": 16,
          "children": [
            {
              "type": "text",
              "id": "page-title",
              "content": "文档中心",
              "fontSize": 40,
              "fontWeight": "700",
              "fill": "$sys/color.text-50"
            },
            {
              "type": "text",
              "id": "page-desc",
              "content": "快速了解 Claude Coder 的完整使用指南",
              "fontSize": 18,
              "fontWeight": "400",
              "fill": "$sys/color.text-400"
            }
          ]
        },
        {
          "type": "frame",
          "id": "content-grid",
          "x": 200,
          "y": 240,
          "width": 1040,
          "height": 1800,
          "layout": "horizontal",
          "gap": 32,
          "children": [
