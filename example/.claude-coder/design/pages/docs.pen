                    },
                    {
                      "type": "text",
                      "id": "getting-started-desc",
                      "content": "三步即可启动你的第一个自主编码 Agent：安装 → 配置 → 运行。",
                      "fontSize": 16,
                      "fontWeight": "400",
                      "fill": "$sys/color.text-400",
                      "lineHeight": 1.6,
                      "y": 48
                    },
                    {
                      "type": "frame",
                      "id": "getting-started-steps",
                      "layout": "vertical",
                      "gap": 12,
                      "y": 90,
                      "children": [
                        {
                          "type": "frame",
                          "id": "step-1",
                          "layout": "horizontal",
                          "gap": 8,
                          "children": [
                            {
                              "type": "text",
                              "id": "arrow-1",
                              "content": "→",
                              "fontSize": 16,
                              "fill": "$sys/color.gradient-start"
                            },
                            {
                              "type": "text",
                              "id": "step-1-link",
                              "content": "安装指南",
                              "fontSize": 14,
                              "fontWeight": "500",
                              "fill": "$sys/color.primary-400"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "step-2",
                          "layout": "horizontal",
                          "gap": 8,
                          "children": [
                            {
                              "type": "text",
                              "id": "arrow-2",
                              "content": "→",
                              "fontSize": 16,
                              "fill": "$sys/color.gradient-start"
                            },
                            {
                              "type": "text",
                              "id": "step-2-text",
                              "content": "模型配置：",
                              "fontSize": 14,
                              "fontWeight": "400",
                              "fill": "$sys/color.text-400"
                            },
                            {
                              "type": "frame",
                              "id": "code-inline-1",
                              "padding": [4, 8, 4, 8],
