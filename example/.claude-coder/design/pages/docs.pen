                              "cornerRadius": 4,
                              "children": [
                                {
                                  "type": "text",
                                  "id": "code-1",
                                  "content": "claude-coder setup",
                                  "fontSize": 13,
                                  "fontWeight": "500",
                                  "fill": "$sys/color.text-200"
                                }
                              ]
                            }
                          ]
                        },
                        {
