{
  "version": "2.8",
  "imports": {
    "sys": "../system.pen"
  },
  "children": [
    {
      "type": "frame",
      "id": "quickstart-page",
      "name": "快速上手",
      "x": 0,
      "y": 0,
      "width": 1440,
      "height": 1400,
      "clip": true,
      "fill": "$sys/color.bg-100",
      "children": [
        {
          "type": "frame",
          "id": "page-header",
          "x": 200,
          "y": 120,
          "width": 800,
          "height": 120,
          "layout": "vertical",
          "gap": 16,
          "children": [
            {
              "type": "text",
              "id": "page-title",
              "content": "快速上手",
              "fontSize": 40,
              "fontWeight": "700",
              "fill": "$sys/color.text-50"
            },
            {
              "type": "text",
              "id": "page-desc",
              "content": "只需几步，开始使用 Claude Coder",
              "fontSize": 18,
              "fontWeight": "400",
              "fill": "$sys/color.text-400"
            }
          ]
        },
        {
          "type": "frame",
          "id": "steps-container",
          "x": 200,
          "y": 260,
          "width": 800,
          "height": 1000,
          "layout": "vertical",
          "gap": 40,
          "children": [
            {
              "type": "frame",
              "id": "step-1",
              "width": 800,
              "height": 180,
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "frame",
                  "id": "step-1-header",
                  "layout": "horizontal",
                  "gap": 12,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "step-1-number",
                      "content": "01",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "fill": "$sys/color.text-400"
                    },
                    {
                      "type": "text",
                      "id": "step-1-title",
                      "content": "安装",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "fill": "$sys/color.text-50"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "code-block-1",
                  "width": 780,
                  "height": 120,
                  "fill": "$sys/color.bg-200",
                  "border": {
                    "thickness": 1,
                    "fill": "$sys/color.border-300"
                  },
                  "cornerRadius": 8,
                  "padding": [16, 16, 16, 16],
                  "children": [
                    {
                      "type": "text",
                      "id": "code-1-title",
                      "content": "安装依赖",
                      "fontSize": 12,
                      "fontWeight": "600",
                      "fill": "$sys/color.text-400",
                      "x": 0,
                      "y": 0
                    },
                    {
                      "type": "text",
                      "id": "code-1-content",
                      "content": "# 安装 Claude Agent SDK\nnpm install -g @anthropic-ai/claude-agent-sdk\n\n# 安装 Claude Coder\nnpm install -g claude-coder",
                      "fontSize": 14,
                      "fontWeight": "400",
                      "fill": "$sys/color.text-200",
                      "x": 0,
                      "y": 24,
                      "lineHeight": 1.5
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "step-2",
              "width": 800,
              "height": 180,
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "frame",
                  "id": "step-2-header",
                  "layout": "horizontal",
                  "gap": 12,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "step-2-number",
                      "content": "02",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "fill": "$sys/color.text-400"
                    },
                    {
                      "type": "text",
                      "id": "step-2-title",
                      "content": "配置",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "fill": "$sys/color.text-50"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "code-block-2",
                  "width": 780,
                  "height": 120,
                  "fill": "$sys/color.bg-200",
                  "border": {
                    "thickness": 1,
                    "fill": "$sys/color.border-300"
                  },
                  "cornerRadius": 8,
                  "padding": [16, 16, 16, 16],
                  "children": [
                    {
                      "type": "text",
                      "id": "code-2-title",
                      "content": "配置环境",
                      "fontSize": 12,
                      "fontWeight": "600",
                      "fill": "$sys/color.text-400",
                      "x": 0,
                      "y": 0
                    },
                    {
                      "type": "text",
                      "id": "code-2-content",
                      "content": "# 交互式配置（模型、MCP、安全限制）\nclaude-coder setup\n\n# 或手动配置环境变量\necho \"ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5\" >> .env",
                      "fontSize": 14,
                      "fontWeight": "400",
                      "fill": "$sys/color.text-200",
                      "x": 0,
                      "y": 24,
                      "lineHeight": 1.5
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "step-3",
              "width": 800,
              "height": 120,
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "frame",
                  "id": "step-3-header",
                  "layout": "horizontal",
                  "gap": 12,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "step-3-number",
                      "content": "03",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "fill": "$sys/color.text-400"
                    },
                    {
                      "type": "text",
                      "id": "step-3-title",
                      "content": "初始化项目",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "fill": "$sys/color.text-50"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "code-block-3",
                  "width": 780,
                  "height": 60,
                  "fill": "$sys/color.bg-200",
                  "border": {
                    "thickness": 1,
                    "fill": "$sys/color.border-300"
                  },
                  "cornerRadius": 8,
                  "padding": [16, 16, 16, 16],
                  "children": [
                    {
                      "type": "text",
                      "id": "code-3-content",
                      "content": "cd your-project\nclaude-coder init",
                      "fontSize": 14,
                      "fontWeight": "400",
                      "fill": "$sys/color.text-200",
                      "lineHeight": 1.5
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "step-4",
              "width": 800,
              "height": 280,
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "frame",
                  "id": "step-4-header",
                  "layout": "horizontal",
                  "gap": 12,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "step-4-number",
                      "content": "04",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "fill": "$sys/color.text-400"
                    },
                    {
                      "type": "text",
                      "id": "step-4-title",
                      "content": "开始编码",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "fill": "$sys/color.text-50"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "code-block-4",
                  "width": 780,
                  "height": 180,
                  "fill": "$sys/color.bg-200",
                  "border": {
                    "thickness": 1,
                    "fill": "$sys/color.border-300"
                  },
                  "cornerRadius": 8,
                  "padding": [16, 16, 16, 16],
                  "children": [
                    {
                      "type": "text",
                      "id": "code-4-title",
                      "content": "运行命令",
                      "fontSize": 12,
                      "fontWeight": "600",
                      "fill": "$sys/color.text-400",
                      "x": 0,
                      "y": 0
                    },
                    {
                      "type": "text",
                      "id": "code-4-content",
                      "content": "# 方式一：直接输入需求\nclaude-coder run \"实现用户注册和登录功能\"\n\n# 方式二：从需求文件读取\nclaude-coder run\n\n# 方式三：交互模式\nclaude-coder plan -i \"需求描述\"",
                      "fontSize": 14,
                      "fontWeight": "400",
                      "fill": "$sys/color.text-200",
                      "x": 0,
                      "y": 24,
                      "lineHeight": 1.5
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "options-list",
                  "layout": "vertical",
                  "gap": 12,
                  "children": [
                    {
                      "type": "frame",
                      "id": "option-1",
                      "layout": "horizontal",
                      "gap": 8,
                      "children": [
                        {
                          "type": "text",
                          "id": "opt-code-1",
                          "content": "--max N",
                          "fontSize": 13,
                          "fontWeight": "500",
                          "fill": "$sys/color.lazy-cyan",
                          "background": "$sys/color.bg-100",
                          "padding": [2, 8, 2, 8],
                          "cornerRadius": 4
                        },
                        {
                          "type": "text",
                          "id": "opt-desc-1",
                          "content": "限制 session 数（默认 50）",
                          "fontSize": 14,
                          "fontWeight": "400",
                          "fill": "$sys/color.text-400"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "option-2",
                      "layout": "horizontal",
                      "gap": 8,
                      "children": [
                        {
                          "type": "text",
                          "id": "opt-code-2",
                          "content": "--pause N",
                          "fontSize": 13,
                          "fontWeight": "500",
                          "fill": "$sys/color.lazy-cyan",
                          "background": "$sys/color.bg-100",
                          "padding": [2, 8, 2, 8],
                          "cornerRadius": 4
                        },
                        {
                          "type": "text",
                          "id": "opt-desc-2",
                          "content": "每 N 个 session 暂停确认",
                          "fontSize": 14,
                          "fontWeight": "400",
                          "fill": "$sys/color.text-400"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "option-3",
                      "layout": "horizontal",
                      "gap": 8,
                      "children": [
                        {
                          "type": "text",
                          "id": "opt-code-3",
                          "content": "--dry-run",
                          "fontSize": 13,
                          "fontWeight": "500",
                          "fill": "$sys/color.lazy-cyan",
                          "background": "$sys/color.bg-100",
                          "padding": [2, 8, 2, 8],
                          "cornerRadius": 4
                        },
                        {
                          "type": "text",
                          "id": "opt-desc-3",
                          "content": "预览模式（查看任务队列）",
                          "fontSize": 14,
                          "fontWeight": "400",
                          "fill": "$sys/color.text-400"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "option-4",
                      "layout": "horizontal",
                      "gap": 8,
                      "children": [
                        {
                          "type": "text",
                          "id": "opt-code-4",
                          "content": "--model M",
                          "fontSize": 13,
                          "fontWeight": "500",
                          "fill": "$sys/color.lazy-cyan",
                          "background": "$sys/color.bg-100",
                          "padding": [2, 8, 2, 8],
                          "cornerRadius": 4
                        },
                        {
                          "type": "text",
                          "id": "opt-desc-4",
                          "content": "指定模型",
                          "fontSize": 14,
                          "fontWeight": "400",
                          "fill": "$sys/color.text-400"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "step-5",
              "width": 800,
              "height": 120,
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "frame",
                  "id": "step-5-header",
                  "layout": "horizontal",
                  "gap": 12,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "step-5-number",
                      "content": "05",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "fill": "$sys/color.text-400"
                    },
                    {
                      "type": "text",
                      "id": "step-5-title",
                      "content": "验证安装",
                      "fontSize": 24,
                      "fontWeight": "700",
                      "fill": "$sys/color.text-50"
                    },
                    {
                      "type": "icon_font",
                      "id": "step-5-icon",
                      "iconFontFamily": "lucide",
                      "iconFontName": "check-circle",
                      "width": 24,
                      "height": 24,
                      "fill": "$sys/color.success-500"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "code-block-5",
                  "width": 780,
                  "height": 60,
                  "fill": "$sys/color.bg-200",
                  "border": {
                    "thickness": 1,
                    "fill": "$sys/color.border-300"
                  },
                  "cornerRadius": 8,
                  "padding": [16, 16, 16, 16],
                  "children": [
                    {
                      "type": "text",
                      "id": "code-5-content",
                      "content": "claude-coder status\n# 应显示配置信息和模型状态",
                      "fontSize": 14,
                      "fontWeight": "400",
                      "fill": "$sys/color.text-200",
                      "lineHeight": 1.5
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
