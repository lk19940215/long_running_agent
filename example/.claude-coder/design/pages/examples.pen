{
  "version": "2.8",
  "imports": {
    "sys": "../system.pen"
  },
  "children": [
    {
      "type": "frame",
      "id": "examples-page",
      "name": "使用案例",
      "x": 0,
      "y": 0,
      "width": 1440,
      "height": 1600,
      "clip": true,
      "fill": "$sys/color.bg-100",
      "children": [
        {
          "type": "frame",
          "id": "page-header",
          "x": 200,
          "y": 120,
          "width": 800,
          "height": 120,
          "layout": "vertical",
          "gap": 16,
          "children": [
            {
              "type": "text",
              "id": "page-title",
              "content": "使用案例",
              "fontSize": 56,
              "fontWeight": "700",
              "fill": "$sys/color.text-50"
            },
            {
              "type": "text",
              "id": "page-desc",
              "content": "探索 Claude Coder 在实际项目中的应用，了解如何让 AI Agent 为你连续编码",
              "fontSize": 16,
              "fontWeight": "400",
              "fill": "$sys/color.text-400",
              "lineHeight": 1.6
            }
          ]
        },
        {
          "type": "frame",
          "id": "examples-grid",
          "x": 200,
          "y": 260,
          "width": 1040,
          "height": 1200,
          "layout": "grid",
          "gridTemplateColumns": [504, 504],
          "gridAutoRows": 560,
          "gap": 32,
          "children": [
            {
              "type": "frame",
              "id": "example-1",
              "width": 504,
              "height": 560,
              "fill": "$sys/color.bg-200",
              "border": {
                "thickness": 1,
                "fill": "$sys/color.border-300"
              },
              "cornerRadius": 12,
              "padding": [24, 24, 24, 24],
              "children": [
                {
                  "type": "frame",
                  "id": "example-1-header",
                  "layout": "horizontal",
                  "gap": 12,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "example-1-number",
                      "content": "01",
                      "fontSize": 20,
                      "fontWeight": "700",
                      "fill": "$sys/color.text-400"
                    },
                    {
                      "type": "text",
                      "id": "example-1-title",
                      "content": "Todo 应用",
                      "fontSize": 28,
                      "fontWeight": "700",
                      "fill": "$sys/color.text-50"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "example-1-desc",
                  "content": "用 Express + React 快速搭建 Todo 应用。",
                  "fontSize": 14,
                  "fontWeight": "400",
                  "fill": "$sys/color.text-400",
                  "y": 40
                },
                {
                  "type": "frame",
                  "id": "example-1-command",
                  "width": 456,
                  "height": 80,
                  "fill": "$sys/color.bg-100",
                  "border": {
                    "thickness": 1,
                    "fill": "$sys/color.border-300"
                  },
                  "cornerRadius": 8,
                  "padding": [16, 16, 16, 16],
                  "y": 72,
                  "children": [
                    {
                      "type": "text",
                      "id": "example-1-cmd",
                      "content": "claude-coder run \"用 Express + React 做 Todo 应用\"",
                      "fontSize": 14,
                      "fontWeight": "400",
                      "fill": "$sys/color.text-200"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "example-1-result",
                  "layout": "horizontal",
                  "gap": 8,
                  "alignItems": "center",
                  "y": 168,
                  "children": [
                    {
                      "type": "icon_font",
                      "id": "check-1",
                      "iconFontFamily": "lucide",
                      "iconFontName": "check-circle",
                      "width": 16,
                      "height": 16,
                      "fill": "$sys/color.success-500"
                    },
                    {
                      "type": "text",
                      "id": "result-1",
                      "content": "自动生成前后端代码结构",
                      "fontSize": 12,
                      "fontWeight": "500",
                      "fill": "$sys/color.text-400"
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "example-2",
              "width": 504,
              "height": 560,
