                          "fontSize": 30,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "stat-1-label",
                          "fill": "$sys:color.text-muted",
                          "content": "Sessions 自动运行",
                          "fontFamily": "Inter, system-ui, sans-serif",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
