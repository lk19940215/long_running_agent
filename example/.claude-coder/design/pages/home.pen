      "x": 0,
      "y": 0,
      "width": 1440,
      "height": 3000,
      "clip": true,
      "fill": "$sys/color.bg-100",
      "children": [
        {
          "type": "frame",
          "id": "hero-section",
          "name": "Hero 区域",
          "x": 0,
          "y": 64,
          "width": 1440,
          "height": 640,
          "fill": "$sys/color.bg-100",
          "padding": [160, 0, 80, 0],
          "children": [
            {
              "type": "frame",
              "id": "hero-content",
              "x": 200,
              "y": 160,
              "width": 1040,
              "height": 400,
              "layout": "vertical",
              "gap": 24,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "hero-title",
                  "content": "Claude Coder",
                  "fontSize": 64,
                  "fontWeight": "700",
                  "fill": {
                    "type": "linear_gradient",
                    "from": "$sys/color.gradient-start",
                    "to": "$sys/color.gradient-end"
                  },
                  "textAlign": "center"
                },
                {
                  "type": "text",
                  "id": "hero-subtitle",
                  "content": "摸鱼神器 🐟",
                  "fontSize": 28,
                  "fontWeight": "600",
                  "fill": "$sys/color.lazy-cyan",
                  "textAlign": "center"
                },
                {
                  "type": "text",
                  "id": "hero-desc",
                  "content": "AI 加班你摸鱼，Claude Coder 帮你搞定一切。\n一句话需求 → 完整项目。长时间自运行，自动分解任务、持续编码、验证交付。",
                  "fontSize": 18,
                  "fontWeight": "400",
                  "fill": "$sys/color.text-300",
                  "textAlign": "center",
                  "lineHeight": 1.6
                },
                {
                  "type": "frame",
                  "id": "hero-cta",
                  "layout": "horizontal",
