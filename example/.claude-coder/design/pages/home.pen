                      "type": "text",
                      "id": "features-subtitle",
                      "fill": "$sys:color.text-muted",
                      "textGrowth": "fixed-width",
                      "width": 672,
                      "content": "让 AI 成为真正的编码伙伴，从需求到交付，全程自主执行",
                      "textAlign": "center",
                      "fontFamily": "Inter, system-ui, sans-serif",
                      "fontSize": 18,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "features-grid",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 32,
                  "children": [
                    {
                      "type": "frame",
                      "id": "features-row-1",
                      "width": "fill_container",
                      "gap": 32,
                      "children": [
                        {
                          "id": "feature-1",
                          "type": "ref",
                          "ref": "sys:feature-card",
                          "y": 0,
                          "descendants": {
                            "sys:feature-card-icon-symbol": {
                              "content": "⚡"
                            },
                            "sys:feature-card-title": {
                              "content": "一句话需求 → 完整项目"
                            },
                            "sys:feature-card-desc": {
                              "content": "告别繁琐的手动编码。自然语言描述需求，AI 自动分解为可执行任务队列，从零到交付一气呵成。"
                            }
                          }
                        },
                        {
                          "id": "feature-2",
                          "type": "ref",
                          "ref": "sys:feature-card",
                          "x": 432,
                          "y": 0,
                          "descendants": {
                            "sys:feature-card-icon-symbol": {
                              "content": "🔄"
                            },
                            "sys:feature-card-title": {
                              "content": "数小时无人值守"
                            },
                            "sys:feature-card-desc": {
                              "content": "Session 守护 + 倒计时活跃度监控 + git 回滚重试，Agent 持续编码数小时不中断。"
                            }
                          }
                        },
                        {
                          "id": "feature-3",
                          "type": "ref",
                          "ref": "sys:feature-card",
                          "x": 864,
                          "y": 0,
                          "descendants": {
                            "sys:feature-card-icon-symbol": {
                              "content": "🛡"
                            },
                            "sys:feature-card-title": {
                              "content": "Hook 注入 · 安全可控"
                            },
                            "sys:feature-card-desc": {
                              "content": "JSON 配置即可在工具调用时注入规则引导，零代码修改扩展 AI 行为，代码审查自动护航。"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "features-row-2",
                      "width": "fill_container",
                      "gap": 32,
                      "children": [
                        {
                          "id": "feature-4",
                          "type": "ref",
                          "ref": "sys:feature-card",
                          "y": 0,
                          "descendants": {
                            "sys:feature-card-icon-symbol": {
                              "content": "🔀"
                            },
                            "sys:feature-card-title": {
                              "content": "任意模型 · 自由切换"
                            },
                            "sys:feature-card-desc": {
                              "content": "支持 Claude、DeepSeek、GLM-5、Qwen 等任意 Anthropic 兼容 API，多模型路由灵活编排。"
                            }
                          }
                        },
                        {
                          "id": "feature-5",
                          "type": "ref",
                          "ref": "sys:feature-card",
                          "x": 432,
                          "y": 0,
                          "descendants": {
                            "sys:feature-card-icon-symbol": {
                              "content": "🧪"
                            },
                            "sys:feature-card-title": {
                              "content": "E2E 测试自动化"
                            },
                            "sys:feature-card-desc": {
                              "content": "Playwright 登录态一键导出、API Key 持久化存储，Agent 编码后自动验证，交付即可用。"
                            }
                          }
                        },
                        {
                          "id": "feature-6",
                          "type": "ref",
                          "ref": "sys:feature-card",
                          "x": 864,
                          "y": 0,
                          "descendants": {
                            "sys:feature-card-icon-symbol": {
                              "content": "⚙"
                            },
                            "sys:feature-card-title": {
                              "content": "配置驱动 · 开箱即用"
                            },
                            "sys:feature-card-desc": {
                              "content": "JSON 配置 + 环境变量 + CLI 参数三位一体，claude-coder setup 一键配好，即刻开跑。"
                            }
