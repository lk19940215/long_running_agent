{
  "version": "2.9",
  "children": [
    {
      "type": "frame",
      "id": "page-root",
      "x": 0,
      "y": 0,
      "width": 1440,
      "fill": "$sys:color.bg",
      "layout": "vertical",
      "children": [
        {
          "id": "section-header",
          "type": "ref",
          "ref": "sys:header"
        },
        {
          "type": "frame",
          "id": "hero-section",
          "width": "fill_container",
          "fill": "$sys:color.bg",
          "layout": "vertical",
          "padding": [
            128,
            32,
            80,
            32
          ],
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "hero-content",
              "width": 1280,
              "layout": "vertical",
              "gap": 24,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "hero-title",
                  "fill": {
                    "type": "gradient",
                    "gradientType": "linear",
                    "enabled": true,
                    "rotation": 90,
                    "size": {
                      "height": 1
                    },
                    "colors": [
                      {
                        "color": "#8B5CF6",
                        "position": 0
                      },
                      {
                        "color": "#EC4899",
                        "position": 1
                      }
                    ]
                  },
                  "content": "Claude Coder",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 60,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "hero-subtitle",
                  "fill": "$sys:color.accent",
                  "content": "摸鱼神器 🐟",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 24,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "hero-desc",
                  "fill": "$sys:color.text-muted",
                  "textGrowth": "fixed-width",
                  "width": 672,
                  "content": "AI 加班你摸鱼，Claude Coder 帮你搞定一切。\n一句话需求 → 完整项目。长时间自运行，自动分解任务、持续编码、验证交付。",
                  "textAlign": "center",
                  "fontFamily": "Inter, system-ui, sans-serif",
                  "fontSize": 18,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "hero-buttons",
                  "gap": 16,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "frame",
                      "id": "hero-cta-btn",
                      "height": 48,
                      "fill": "$sys:color.primary",
                      "cornerRadius": 12,
                      "padding": [
                        0,
                        32
                      ],
                      "justifyContent": "center",
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "text",
                          "id": "hero-cta-label",
                          "fill": "#FFFFFF",
                          "content": "开始使用",
                          "fontFamily": "Inter, system-ui, sans-serif",
                          "fontSize": 16,
                          "fontWeight": "600"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "hero-github-link",
                      "fill": "$sys:color.text-muted",
                      "content": "View on GitHub",
                      "fontFamily": "Inter, system-ui, sans-serif",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "hero-stats",
                  "gap": 64,
                  "padding": [
                    64,
                    0,
                    0,
                    0
                  ],
                  "children": [
                    {
                      "type": "frame",
                      "id": "stat-1",
                      "layout": "vertical",
                      "gap": 8,
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "text",
                          "id": "stat-1-num",
                          "fill": "$sys:color.text",
