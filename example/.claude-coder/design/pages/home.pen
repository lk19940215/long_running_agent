                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "features-section",
          "width": "fill_container",
          "fill": "$sys:color.bg",
          "layout": "vertical",
          "padding": 80,
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "features-content",
              "width": 1280,
              "layout": "vertical",
              "gap": 64,
              "alignItems": "center",
              "children": [
                {
                  "type": "frame",
                  "id": "features-header",
                  "layout": "vertical",
                  "gap": 16,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "features-title",
                      "fill": "$sys:color.text",
                      "content": "核心特性",
                      "fontFamily": "Inter, system-ui, sans-serif",
