# macOS
.DS_Store

# 模型配置（含 API Key，由 setup.sh 生成）
config.env

# 运行时生成文件（项目特定，不随工具分发）
project_profile.json
init.sh
tasks.json
progress.txt
session_result.json
sync_state.json
requirements_hash.current

# 运行时临时文件（由 hooks/phase-signal.py 和 run.sh 写入）
.phase
.phase_step
.activity_log
logs/

# 测试注册表（运行时生成）
tests.json

# 自定义校验钩子目录（用户自行维护）
validate.d/
